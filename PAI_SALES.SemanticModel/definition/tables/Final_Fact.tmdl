	column 'First Purchase Date' =
			
			CALCULATE(
			    MIN('Final_Fact'[DocDate]),
			    ALLEXCEPT('Final_Fact','Final_Fact'[CardCode])
			)
		formatString: General Date
		lineageTag: 0b819d49-d887-4ca6-9c8d-1f9ce10b7800
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 6e02daa7-1490-4e9e-a09d-a37fa2f7bcf2
			defaultHierarchy: LocalDateTable_6615849f-d76d-449f-a33d-2e8739d4879f.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column 'New or Old' = ```
			
			VAR First_Date =
			    Final_Fact[First Purchase Date]
			 
			RETURN
			IF(
			    YEAR(Final_Fact[DocDate]) = YEAR(First_Date)
			        &&
			    MONTH(Final_Fact[DocDate]) = MONTH(First_Date)
			        &&
			    DAY(Final_Fact[DocDate]) = DAY(First_Date),
			    "New",
			    "Old"
			)
			 
			```
		lineageTag: f3264924-e632-4241-9dc1-dead4c903486
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Actual PSP' =
			
			SWITCH(
			    RELATED('Warehouse_Master'[State]),
			    "KA", Final_Fact[U_PSPKA],
			    "AP", Final_Fact[U_PSPAP],
			    "TS", Final_Fact[U_PSPTS],
			    "MH", Final_Fact[U_PSPAP]
			)
