	column Finance_Contributors =
			
			SWITCH(
			    TRUE(),
			    Final_Fact[TrnspName] = "NA", "DIRECT",
			    Final_Fact[TrnspName] = "BAJAJ FINANCE","BAJAJ",
			    Final_Fact[TrnspName] = "FUR BAJAJ FINANCE", "FUR BAJAJ",
			    Final_Fact[TrnspName] = "HDB FINANCE", "HDB",
