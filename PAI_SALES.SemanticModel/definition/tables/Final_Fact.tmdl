	column 'Gtotal Range' =
			
			SWITCH (
			    TRUE(),
			    'Final_Fact'[Gtotal] < 0, "Sales Return",
			    'Final_Fact'[Gtotal] <= 5000, "0 - 5000",
			    'Final_Fact'[Gtotal] <= 20000, "5001 - 20000",
			    'Final_Fact'[Gtotal] <= 30000, "20001 - 30000",
			    'Final_Fact'[Gtotal] <= 40000, "30001 - 40000",
			    'Final_Fact'[Gtotal] <= 50000, "40001 - 50000",
			    'Final_Fact'[Gtotal] <= 65000, "50001 - 65000",
			    'Final_Fact'[Gtotal] <= 80000, "65001 - 80000",
			    'Final_Fact'[Gtotal] <= 100000, "80001 - 100000",
			    'Final_Fact'[Gtotal] <= 120000, "100001 - 120000",
			    "Above 120000"
			)
		lineageTag: 4e9e241c-03da-4bb6-941a-516c66e5bce6
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Gross Profit' = ```
			
