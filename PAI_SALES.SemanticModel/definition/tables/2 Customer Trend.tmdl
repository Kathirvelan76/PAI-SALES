	partition '2 Customer Trend' = calculated
		mode: import
		source =
				
				SUMMARIZE(
				    FILTER(
				        'Final_Fact',
				        'Final_Fact'[Type] = "SI"
				    ),
				    'Final_Fact'[CardCode],
				    'Final_Fact'[Order_Branch_Code],
				    "CardName", MAX('Final_Fact'[CardName]),
				    "Purchase Count", DISTINCTCOUNT('Final_Fact'[DocEntry]),
				    "First Purchase Date", MIN('Final_Fact'[DocDate]),
				    "Last Purchase Date", MAX('Final_Fact'[DocDate])
				)

	annotation PBI_Id = 02d38cb721c14eb09035fe68e7470f10

