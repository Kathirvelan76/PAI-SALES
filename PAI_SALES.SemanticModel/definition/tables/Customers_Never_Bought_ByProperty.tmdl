table Customers_Never_Bought_ByProperty
	lineageTag: bd9f84b6-4f83-4a56-990b-78f3a642630f

	column CardCode
		lineageTag: dfca622d-97c4-4643-9d85-89b2b4dcb5ce
		summarizeBy: none
		isNameInferred
		sourceColumn: Cust_Vend_Master[CardCode]

		annotation SummarizationSetBy = Automatic

	partition Customers_Never_Bought_ByProperty = calculated
		mode: import
		source =
				
				VAR SelectedProperty = SELECTEDVALUE('Category Slicer'[Property])
				
				VAR BoughtInProperty =
				    SELECTCOLUMNS(
				        FILTER(
				            'Customer_MainCategory',
				            'Customer_MainCategory'[Property] = SelectedProperty
				        ),
				        "CardCode", 'Customer_MainCategory'[CardCode]
				    )
				
				VAR AllCustomers =
				    DISTINCT('Cust_Vend_Master'[CardCode])
				
				RETURN
				    EXCEPT(AllCustomers, BoughtInProperty)

	annotation PBI_Id = d1186addabf1477abe2c67ca7de348a7

