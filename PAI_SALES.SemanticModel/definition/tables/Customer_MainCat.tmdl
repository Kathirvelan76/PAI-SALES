	partition Customer_MainCat = calculated
		mode: import
		source =
				
				SUMMARIZE (
				    FILTER(
				        Final_Fact,
				        Final_Fact[Type] = "SI"
				    ),
				    Final_Fact[CardCode],
				    Item_Master[Property],
				    "Purchase Count", DISTINCTCOUNT ( Final_Fact[DocEntry] ),
				    "First Purchase Date", MIN ( Final_Fact[DocDate]),
				    "Last Purchase Date", MAX ( Final_Fact[DocDate])
				)

	annotation PBI_Id = 8b2379e172b04ea6be2fe3c13a6f2134

