	measure 'Never Bought Flag' =
			
			VAR SelectedProperty =
			    SELECTEDVALUE('Category Slicer'[Property])
			
			VAR CurrentCustomer =
			    MAX('Cust_Vend_Master'[CardCode])
			
			VAR BoughtInProperty =
			    CALCULATETABLE(
			        DISTINCT('Customer_MainCategory'[CardCode]),
			        'Customer_MainCategory'[Property] = SelectedProperty,
			        REMOVEFILTERS('Cust_Vend_Master'),
			        REMOVEFILTERS('Warehouse_Master')
			    )
			
			RETURN
			    IF(
			        NOT ISBLANK(SelectedProperty),
			        IF(NOT(CurrentCustomer IN BoughtInProperty), 1, 0),
			        BLANK()
			    )
		formatString: 0
		displayFolder: Not Purchased Category
