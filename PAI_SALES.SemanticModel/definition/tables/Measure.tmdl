	measure 'Customer Only In Selected Year' =
			
			VAR _SelYear =
			    SELECTEDVALUE ( 'DateTable'[Year] )
			RETURN
			IF (
			    NOT ISBLANK ( _SelYear ) &&
			    MAX ( '2 Customer Trend'[First Year] ) = _SelYear &&
			    MAX ( '2 Customer Trend'[Last Year] )  = _SelYear,
			    1,
			    0
			)
		formatString: 0
		displayFolder: Only One Year
		lineageTag: e9b59393-da5d-48ee-bf7b-f1503010dc92

	measure 'Exact Purchase Count Match' =
			
			VAR _SelectedCount =
			    SELECTEDVALUE ( 'Purchase Count Slicer'[Count Filter] )
			
			VAR _CustomerPurchaseCount =
			    MAX ( '2 Customer Trend'[Purchase Count] )
			
			RETURN
			IF (
			    ISBLANK ( _SelectedCount ) ||
			    _CustomerPurchaseCount = _SelectedCount,
			    1,
			    0
			)
		formatString: 0
		displayFolder: Only One Year
		lineageTag: c1461954-8465-4fbc-8b4e-92734d00c055

	measure 'Final Eligible Customer' =
			
			IF (
			    [Customer Only In Selected Year] = 1 &&
			    [Exact Purchase Count Match] = 1,
			    1,
			    0
			)
		formatString: 0
		displayFolder: Only One Year
		lineageTag: d29aa54f-403c-4606-ba0c-07bf5371ff95

	measure CustomerBranchValidFlag =
			
			VAR YearsPurchased =
			    CALCULATE (
			        DISTINCTCOUNT ( Final_Fact[Year] ),
			        Final_Fact[Type] = "SI",
			        ALLEXCEPT ( Final_Fact, Final_Fact[CardCode], Final_Fact[Order_Branch_Code] )
			    )
			
			VAR MinYear =
			    CALCULATE (
			        MIN ( Final_Fact[Year] ),
			        Final_Fact[Type] = "SI",
			        ALLEXCEPT ( Final_Fact, Final_Fact[CardCode], Final_Fact[Order_Branch_Code] )
			    )
			
			VAR MaxYear =
			    CALCULATE (
			        MAX ( Final_Fact[Year] ),
			        Final_Fact[Type] = "SI",
			        ALLEXCEPT ( Final_Fact, Final_Fact[CardCode], Final_Fact[Order_Branch_Code] )
			    )
			
			RETURN
			IF ( YearsPurchased = 4 && MinYear = 2022 && MaxYear = 2025, 1, 0 )
		formatString: 0
		displayFolder: Only One Year
		lineageTag: ea5c1374-830f-430a-b14b-fbf6babb6945

