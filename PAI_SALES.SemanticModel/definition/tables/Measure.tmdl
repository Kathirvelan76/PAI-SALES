	measure '2 Quantity Previous Period' = ```
			
			
			VAR _HasYear  = ISFILTERED('DateTable'[FY Start Year])
			VAR _HasMonth = ISFILTERED('DateTable'[Month No])
			
			VAR _SelYear  = SELECTEDVALUE('DateTable'[FY Start Year])
			VAR _SelMonth = SELECTEDVALUE('DateTable'[Month No])
			
			-- Unit selection (default to Lakhs)
			VAR _SelectedUnit = SELECTEDVALUE('Measure'[Unit], "Lakhs (L)")
			
			VAR _Divisor =
			    SWITCH(
			        _SelectedUnit,
			        "Crores (Cr)",   10000000,
			        "Lakhs (L)",     100000,
			        "Thousands (K)", 1000,
			        "Numbers (N)", 1,
			        1
			    )
			
			VAR _UnitSuffix =
			    SWITCH(
			        _SelectedUnit,
			        "Crores (Cr)",   "Cr",
			        "Lakhs (L)",     "L",
			        "Thousands (K)", "K",
			        "Numbers (N)", "",
			        ""
			    )
			
			------------------------------------------------------
			-- Case 1: ONLY YEAR selected → Compare full year
			------------------------------------------------------
			VAR _PrevYear_Total =
			    CALCULATE(
			        DIVIDE([Quantity Total], _Divisor),
			        REMOVEFILTERS('DateTable'[FY Start Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _SelYear - 1
			    )
			
			VAR _CurrYear_Total =
			    CALCULATE(
			        DIVIDE([Quantity Total], _Divisor),
			        'DateTable'[FY Start Year] = _SelYear
			    )
			
			------------------------------------------------------
			-- Case 2: YEAR + MONTH selected → Previous month logic
			------------------------------------------------------
			VAR _PrevMonth =
			    IF(_SelMonth = 1, 12, _SelMonth - 1)
			
			VAR _PrevMonthYear =
			    IF(_SelMonth = 1, _SelYear - 1, _SelYear)
			
			VAR _PrevMonth_Total =
			    CALCULATE(
			        DIVIDE([Quantity Total], _Divisor),
			        REMOVEFILTERS('DateTable'[FY Start Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _PrevMonthYear,
			        'DateTable'[Month No] = _PrevMonth
			    )
			
			VAR _CurrMonth_Total =
			    CALCULATE(
			        DIVIDE([Quantity Total], _Divisor)
			    )
			
			------------------------------------------------------
			-- Differences
			------------------------------------------------------
			VAR _Diff_Year  = _CurrYear_Total  - _PrevYear_Total
			VAR _Perc_Year  = DIVIDE(_Diff_Year, _PrevYear_Total)
			
			VAR _Diff_Month = _CurrMonth_Total - _PrevMonth_Total
			VAR _Perc_Month = DIVIDE(_Diff_Month, _PrevMonth_Total)
			
			VAR _Arrow_Year  = IF(_Diff_Year  > 0, "⇧", IF(_Diff_Year  < 0, "⇩", ""))
			VAR _Arrow_Month = IF(_Diff_Month > 0, "⇧", IF(_Diff_Month < 0, "⇩", ""))
			
			------------------------------------------------------
			-- Final Output
			------------------------------------------------------
			RETURN
			SWITCH(
			    TRUE(),
			
			    -- Output if only Year selected
			    _HasYear && NOT _HasMonth,
			        "vs Previous Year : " &
			        _Arrow_Year & " " &
			        FORMAT(_Diff_Year, "#,##0.00") & " " & _UnitSuffix &
			        " | " & FORMAT(_Perc_Year, "0.0%"),
			
			    -- Output if Year + Month selected
			    _HasYear && _HasMonth,
			        "vs Previous Period : " &
			        _Arrow_Month & " " &
			        FORMAT(_Diff_Month, "#,##0.00") & " " & _UnitSuffix &
			        " | " & FORMAT(_Perc_Month, "0.0%"),
			
			    -- If no time selected
			    NOT _HasYear && NOT _HasMonth,
			        "vs Previous :",
			
			    BLANK()
			)
			
			```
		displayFolder: Quantity
		lineageTag: 4c62bee3-930d-456d-a2f1-c405c210c6ed

	measure '2 Sales Chart' = ```
			
			VAR SelectedUnit = SELECTEDVALUE ( 'Measure'[Unit], "Crores (Cr)" )
			RETURN
			    SWITCH (
			        SelectedUnit,
			        "Thousands (K)", DIVIDE ( [Sales Total], 1000 ),
			        "Lakhs (L)", DIVIDE ( [Sales Total], 100000 ),
			        "Crores (Cr)", DIVIDE ( [Sales Total], 10000000 ),
			        "Numbers (N)", DIVIDE ( [Sales Total], 1 ),
			        DIVIDE ( [Sales Total], 10000000 )  
			    )
