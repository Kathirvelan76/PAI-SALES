	measure 'Avg PSP' =
			
			DIVIDE(
			    SUMX(
			        Final_Fact,
			        VAR State = RELATED('Warehouse_Master'[State])
			        VAR PSP =
			            SWITCH(
			                State,
			                "KA", Final_Fact[U_PSPKA],
			                "AP", Final_Fact[U_PSPAP],
			                "TS", Final_Fact[U_PSPTS]
			            )
			        RETURN Final_Fact[Qty] * PSP
			    ),
			    SUM(Final_Fact[Qty])
			)
		displayFolder: Selling Price
		lineageTag: cc1c6252-281b-4e03-86f1-2282ae9b439b

