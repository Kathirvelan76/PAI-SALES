			VAR _businesstype =
			    IF(
			        ISFILTERED('Final_Fact'[Business Type]),
			        "Business Type(" & CONCATENATEX(VALUES('Final_Fact'[Business Type]), 'Final_Fact'[Business Type], ", ") & ")",
			        BLANK()
			    )
			
			VAR _trnspname =
			    IF(
			        ISFILTERED('Final_Fact'[TrnspName]),
			        "Trnsp Name(" & CONCATENATEX(VALUES('Final_Fact'[TrnspName]), 'Final_Fact'[TrnspName], ", ") & ")",
			        BLANK()
			    )
			
			Var _month =
			    If(
			        ISFILTERED('DateTable'[Month Name]),
			        "Month(" & CONCATENATEX(VALUES('DateTable'[Month Name]), 'DateTable'[Month Name], ", ") & ")",
			        BLANK()
			        )
			
			Var _minbill =
			    If(
			        ISFILTERED('Min Bill Amount'[Min Bill Amount]),
			        "Min. Invoice Value(" & CONCATENATEX(VALUES('Min Bill Amount'[Min Bill Amount]), 'Min Bill Amount'[Min Bill Amount], ", ") & ")",
			        BLANK()
			        )
			Var _maxbill =
			    If(
			        ISFILTERED('Max Bill Amount'[Max Bill Amount]),
			        "Max. Invoice Value(" & CONCATENATEX(VALUES('Max Bill Amount'[Max Bill Amount]), 'Max Bill Amount'[Max Bill Amount], ", ") & ")",
			        BLANK()
			        )
			Var _purchasecount =
			    If(
			        ISFILTERED('Purchase Count Slicer'[Count Filter]),
			        "Purchase Count(" & CONCATENATEX(VALUES('Purchase Count Slicer'[Count Filter]), 'Purchase Count Slicer'[Count Filter], ", ") & ")",
			        BLANK()
			        )
			Var _LastNmonth =
			    If(
			        ISFILTERED('Last N Months'[Value]),
			        "Last N Months(" & CONCATENATEX(VALUES('Last N Months'[Value]), 'Last N Months'[Value], ", ") & ")",
			        BLANK()
			        )
			
			Var _year =
			    If(
			        ISFILTERED('DateTable'[Year]),
			        "Year(" & CONCATENATEX(VALUES('DateTable'[Year]), 'DateTable'[Year], ", ") & ")",
			        BLANK()
			        )
			
			Var _state =
			    If(
			        ISFILTERED('Warehouse_Master'[State]),
			        "State(" & CONCATENATEX(VALUES('Warehouse_Master'[State]), 'Warehouse_Master'[State], ", ") & ")",
			        BLANK()
			        )
			
			Var _mainCategory =
			    If(
			        ISFILTERED('Item_Master'[Property]),
			        "Main Category(" & CONCATENATEX(VALUES('Item_Master'[Property]), 'Item_Master'[Property], ", ") & ")",
			        BLANK()
			        )
			
			Var _custseg =
			    If(
			        ISFILTERED('Customer Trend'[Segment]),
			        "Customer Segment(" & CONCATENATEX(VALUES('Customer Trend'[Segment]), 'Customer Trend'[Segment], ", ") & ")",
			        BLANK()
			        )
			    
			Var _range =
			    If(
			        ISFILTERED('Final_Fact'[Gtotal Range]),
			        "Range(" & CONCATENATEX(VALUES('Final_Fact'[Gtotal Range]), 'Final_Fact'[Gtotal Range], ", ") & ")",
			        BLANK()
			        )
			
			Var _date=
			    If(
			        ISFILTERED('DateTable'[Date]),
			        "Date(" & CONCATENATEX(VALUES('DateTable'[Date]), 'DateTable'[Date], ", ") & ")",
			        BLANK()
			        )
			
			Var _finyear=
			    If(
			        ISFILTERED('DateTable'[Financial Year]),
			        "Finc.Year(" & CONCATENATEX(VALUES('DateTable'[Financial Year]), 'DateTable'[Financial Year], ", ") & ")",
			        BLANK()
			        )
			
			Var _newold=
			    If(
			        ISFILTERED('Final_Fact'[New or Old]),
			        "Customer Type(" & CONCATENATEX(VALUES('Final_Fact'[New or Old]), 'Final_Fact'[New or Old], ", ") & ")",
			        BLANK()
			        )
			
			Var _mainnew=
			    If(
			        ISFILTERED('Category Slicer'[Property]),
			        "Main Category(" & CONCATENATEX(VALUES('Category Slicer'[Property]), 'Category Slicer'[Property], ", ") & ")",
			        BLANK()
			        )
			
			Var _itemcount=
			    If(
			        ISFILTERED('Final_Fact'[Item Count Chart]),
			        "Item Count(" & CONCATENATEX(VALUES('Final_Fact'[Item Count Chart]), 'Final_Fact'[Item Count Chart], ", ") & ")",
			        BLANK()
			        )
			
			Var _basketsize=
			    If(
			        ISFILTERED('Final_Fact'[DocTotal Range]),
			        "Basket Size(" & CONCATENATEX(VALUES('Final_Fact'[DocTotal Range]), 'Final_Fact'[DocTotal Range], ", ") & ")",
			        BLANK()
			        )
			
			
			VAR _filters =
			    CONCATENATEX(
			        FILTER(
			            {
			                _brand,
			                _groupCategory,
			                _headCategory,
			                _subCategory,
			                _movement,
			                _size,
			                _star,
			                _month,
			                _minbill,
			                _maxbill,
			                _purchasecount,
			                _LastNmonth,
			                _segment,
			                _trnspname,
			                _businesstype,
			                _salestype,
			                _Branch,
			                _year,
			                _state,
			                _mainCategory,
			                _custseg,
			                _range,
			                _date,
			                _finyear,
			                _newold,
			                _mainnew,
			                _itemcount,
			                _basketsize
			
			
			
			            },
			            [Value] <> BLANK()
			        ),
			        [Value],
			        ", "
			    )
			
			RETURN
			IF(
			    LEN(_filters) > 0,
			    "Active Filters: " & _filters,
			    "Active Filters: None"
			)
			
			```
