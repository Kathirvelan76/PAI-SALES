table Measure
	lineageTag: 7e554c4a-7b38-47b3-a28e-76ac33b2a1a5

	measure 'Sales Total' = SUM(Final_Fact[GTotal])
		displayFolder: Sales
		lineageTag: ce4468b0-9a7a-4e47-aaac-0ccbc70ab655

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Use Sales Total' = ```
			
			VAR SelectedUnit = SELECTEDVALUE ( 'Measure'[Unit], "Crores (Cr)" )
			RETURN
			    SWITCH (
			        SelectedUnit,
			        "Crores (Cr)", FORMAT ( DIVIDE ([Sales Total], 10000000),  "₹0.00" ) & " Cr",
			        "Lakhs (L)", FORMAT ( DIVIDE ( [Sales Total], 100000 ), "₹0.00" ) & " L",
			        "Thousands (K)", FORMAT ( DIVIDE ( [Sales Total], 1000 ), "₹0.00" ) & " K",
			        "Numbers (N)", FORMAT (DIVIDE ( [Sales Total], 1 ), "₹0.00" ),
			        FORMAT ( DIVIDE ([Sales Total], 10000000),  "₹0.00" ) & " Cr"
			    )
			
			```
		displayFolder: Sales
		lineageTag: 883a9f11-ead8-4408-9710-cb85a482aa3d

	measure 'Sales Previous Period' =
			
			
			VAR _HasYear  = HASONEVALUE('DateTable'[Financial Year])
			VAR _HasMonth = HASONEVALUE('DateTable'[Month No])
			
			VAR _SelFY =
			    SELECTEDVALUE('DateTable'[Financial Year])
			
			VAR _SelYear =
			    VALUE(LEFT(_SelFY,4))
			
			VAR _SelMonth =
			    SELECTEDVALUE('DateTable'[Month No])
			
			------------------------------------------------
			-- Current Sales
			------------------------------------------------
			
			VAR _CurrValue_Numeric =
			    [Sales Total]
			
			------------------------------------------------
			-- Year Comparison
			------------------------------------------------
			
			VAR _PrevYear_Value =
			    CALCULATE(
			        [Sales Total],
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _SelYear - 1
			    )
			
			VAR _CurrYear_Value =
			    CALCULATE(
			        [Sales Total],
			        'DateTable'[FY Start Year] = _SelYear
			    )
			
			------------------------------------------------
			-- Month Comparison
			------------------------------------------------
			
			VAR _PrevMonth =
			    IF(_SelMonth = 1, 12, _SelMonth - 1)
			
			VAR _PrevMonth_Year =
			    IF(_SelMonth = 1, _SelYear - 1, _SelYear)
			
			VAR _PrevMonth_Value =
			    CALCULATE(
			        [Sales Total],
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _PrevMonth_Year,
			        'DateTable'[Month No] = _PrevMonth
			    )
			
			VAR _CurrMonth_Value =
			    _CurrValue_Numeric
			
			------------------------------------------------
			-- Differences
			------------------------------------------------
			
			VAR _Diff_Year  = _CurrYear_Value  - _PrevYear_Value
			VAR _Perc_Year  = DIVIDE(_Diff_Year, _PrevYear_Value)
			
			VAR _Diff_Month = _CurrMonth_Value - _PrevMonth_Value
			VAR _Perc_Month = DIVIDE(_Diff_Month, _PrevMonth_Value)
			
			VAR _Arrow_Year  = IF(_Diff_Year > 0,"⇧",IF(_Diff_Year < 0,"⇩",""))
			VAR _Arrow_Month = IF(_Diff_Month > 0,"⇧",IF(_Diff_Month < 0,"⇩",""))
			
			------------------------------------------------
			-- Unit Handling (same as your previous measure)
			------------------------------------------------
			
			VAR _SelectedUnit =
			    SELECTEDVALUE('Measure'[Unit], "Crores (Cr)")
			
			VAR _Divisor =
			    SWITCH(
			        _SelectedUnit,
			        "Crores (Cr)",   10000000,
			        "Lakhs (L)",     100000,
			        "Thousands (K)", 1000,
			        "Numbers (N)",   1,
			        1
			    )
			
			VAR _UnitSuffix =
			    SWITCH(
			        _SelectedUnit,
			        "Crores (Cr)",   "Cr",
			        "Lakhs (L)",     "L",
			        "Thousands (K)", "K",
			        "Numbers (N)",   "",
			        ""
			    )
			
			------------------------------------------------
			RETURN
			------------------------------------------------
			
			SWITCH(
			    TRUE(),
			
			    _HasYear && NOT _HasMonth,
			        "vs Previous Year : " &
			        _Arrow_Year & " ₹" &
			        FORMAT(DIVIDE(_Diff_Year,_Divisor),"#,##0.00") & " " & _UnitSuffix &
			        " | " &
			        FORMAT(_Perc_Year,"0.0%"),
			
			    _HasYear && _HasMonth,
			        "vs Previous Period : " &
			        _Arrow_Month & " ₹" &
			        FORMAT(DIVIDE(_Diff_Month,_Divisor),"#,##0.00") & " " & _UnitSuffix &
			        " | " &
			        FORMAT(_Perc_Month,"0.0%"),
			
			    NOT _HasYear && NOT _HasMonth,
			        "vs Previous :",
			
			    BLANK()
			)
		displayFolder: Sales
		lineageTag: 7666b653-8995-4200-a829-1fda0eff212b

	measure 'Color Sales Previous Period' =
			
			
			VAR _HasYear  = HASONEVALUE('DateTable'[Financial Year])
			VAR _HasMonth = HASONEVALUE('DateTable'[Month No])
			
			VAR _SelFY =
			    SELECTEDVALUE('DateTable'[Financial Year])
			
			VAR _SelYear =
			    VALUE(LEFT(_SelFY,4))
			
			VAR _SelMonth =
			    SELECTEDVALUE('DateTable'[Month No])
			
			VAR _CurrValue_Numeric =
			    [Sales Total]
			
			VAR _PrevYear_Value =
			    CALCULATE(
			        [Sales Total],
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _SelYear - 1
			    )
			
			VAR _CurrYear_Value =
			    CALCULATE(
			        [Sales Total],
			        'DateTable'[FY Start Year] = _SelYear
			    )
			
			VAR _PrevMonth =
			    IF(_SelMonth = 1, 12, _SelMonth - 1)
			
			VAR _PrevMonth_Year =
			    IF(_SelMonth = 1, _SelYear - 1, _SelYear)
			
			VAR _PrevMonth_Value =
			    CALCULATE(
			        [Sales Total],
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _PrevMonth_Year,
			        'DateTable'[Month No] = _PrevMonth
			    )
			
			VAR _Diff_Year  = _CurrYear_Value - _PrevYear_Value
			VAR _Diff_Month = _CurrValue_Numeric - _PrevMonth_Value
			
			RETURN
			SWITCH(
			    TRUE(),
			
			    _HasYear && NOT _HasMonth,
			        IF(_Diff_Year > 0,"#36A962",IF(_Diff_Year < 0,"#D44343","#000000")),
			
			    _HasYear && _HasMonth,
			        IF(_Diff_Month > 0,"#36A962",IF(_Diff_Month < 0,"#D44343","#000000")),
			
			    "#000000"
			)
