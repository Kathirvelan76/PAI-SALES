	measure 'Avg Basket Value' =
			
			DIVIDE(
			    SUM('Final_Fact'[Gtotal]),
			    DISTINCTCOUNT('Final_Fact'[DocEntry]),
			    0
			)
		displayFolder: Avg Basket
		lineageTag: c93b31fa-0888-405e-8d64-7b27873f3fef

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Basket Value Previous Period' =
			
			
			VAR _HasYear  = HASONEVALUE('DateTable'[Financial Year])
			VAR _HasMonth = HASONEVALUE('DateTable'[Month No])
			
			VAR _SelFY =
			    SELECTEDVALUE('DateTable'[Financial Year])
			
			VAR _SelYear =
			    VALUE(LEFT(_SelFY,4))
			
			VAR _SelMonth =
			    SELECTEDVALUE('DateTable'[Month No])
			
			------------------------------------------------
			-- Current Sales
			------------------------------------------------
			
			VAR _CurrValue_Numeric =
			    [Avg Basket Value]
			
			------------------------------------------------
			-- Year Comparison
			------------------------------------------------
			
			VAR _PrevYear_Value =
			    CALCULATE(
			        [Avg Basket Value],
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _SelYear - 1
			    )
			
			VAR _CurrYear_Value =
			    CALCULATE(
			        [Avg Basket Value],
			        'DateTable'[FY Start Year] = _SelYear
			    )
			
			------------------------------------------------
			-- Month Comparison
			------------------------------------------------
			
			VAR _PrevMonth =
			    IF(_SelMonth = 1, 12, _SelMonth - 1)
			
			VAR _PrevMonth_Year =
			    IF(_SelMonth = 1, _SelYear - 1, _SelYear)
			
			VAR _PrevMonth_Value =
			    CALCULATE(
			        [Avg Basket Value],
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _PrevMonth_Year,
			        'DateTable'[Month No] = _PrevMonth
			    )
			
			VAR _CurrMonth_Value =
			    _CurrValue_Numeric
			
			------------------------------------------------
			-- Differences
			------------------------------------------------
			
			VAR _Diff_Year  = _CurrYear_Value  - _PrevYear_Value
			VAR _Perc_Year  = DIVIDE(_Diff_Year, _PrevYear_Value)
			
			VAR _Diff_Month = _CurrMonth_Value - _PrevMonth_Value
			VAR _Perc_Month = DIVIDE(_Diff_Month, _PrevMonth_Value)
			
			VAR _Arrow_Year  = IF(_Diff_Year > 0,"⇧",IF(_Diff_Year < 0,"⇩",""))
			VAR _Arrow_Month = IF(_Diff_Month > 0,"⇧",IF(_Diff_Month < 0,"⇩",""))
			
			------------------------------------------------
			-- Unit Handling (same as your previous measure)
			------------------------------------------------
			
			VAR _SelectedUnit =
			    SELECTEDVALUE('Measure'[Unit], "Thousands (K)")
			
			VAR _Divisor =
			    SWITCH(
			        _SelectedUnit,
			        "Lakhs (L)",     100000,
			        "Thousands (K)", 1000,
			        "Numbers (N)",   1,
			        1
			    )
			
			VAR _UnitSuffix =
			    SWITCH(
			        _SelectedUnit,
			        "Lakhs (L)",     "L",
			        "Thousands (K)", "K",
			        "Numbers (N)",   "",
			        ""
			    )
			
			------------------------------------------------
			RETURN
			------------------------------------------------
			
			SWITCH(
			    TRUE(),
			
			    _HasYear && NOT _HasMonth,
			        "vs Previous Year : " &
			        _Arrow_Year & " ₹" &
			        FORMAT(DIVIDE(_Diff_Year,_Divisor),"#,##0.00") & " " & _UnitSuffix &
			        " | " &
			        FORMAT(_Perc_Year,"0.0%"),
			
			    _HasYear && _HasMonth,
			        "vs Previous Period : " &
			        _Arrow_Month & " ₹" &
			        FORMAT(DIVIDE(_Diff_Month,_Divisor),"#,##0.00") & " " & _UnitSuffix &
			        " | " &
			        FORMAT(_Perc_Month,"0.0%"),
			
			    NOT _HasYear && NOT _HasMonth,
			        "vs Previous :",
			
			    BLANK()
			)
		displayFolder: Avg Basket
		lineageTag: 07008623-24ce-44cc-a182-7d29b266cf05

	measure 'Color Avg Basket Previous Period' =
			
			
			VAR _HasYear  = HASONEVALUE('DateTable'[Financial Year])
			VAR _HasMonth = HASONEVALUE('DateTable'[Month No])
			
			VAR _SelFY =
			    SELECTEDVALUE('DateTable'[Financial Year])
			
			VAR _SelYear =
			    VALUE(LEFT(_SelFY,4))
			
			VAR _SelMonth =
			    SELECTEDVALUE('DateTable'[Month No])
			
			VAR _CurrValue_Numeric =
			    DIVIDE(
			        SUM('Final_Fact'[Gtotal]),
			        DISTINCTCOUNT('Final_Fact'[DocEntry]),
			        0
			    ) / 1000
			
			VAR _PrevYear_Value =
			    CALCULATE(
			        DIVIDE(
			            SUM('Final_Fact'[Gtotal]),
			            DISTINCTCOUNT('Final_Fact'[DocEntry]),
			            0
			        ) / 1000,
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _SelYear - 1
			    )
			
			VAR _CurrYear_Value =
			    CALCULATE(
			        DIVIDE(
			            SUM('Final_Fact'[Gtotal]),
			            DISTINCTCOUNT('Final_Fact'[DocEntry]),
			            0
			        ) / 1000,
			        'DateTable'[FY Start Year] = _SelYear
			    )
			
			VAR _PrevMonth =
			    IF(_SelMonth = 1, 12, _SelMonth - 1)
			
			VAR _PrevMonth_Year =
			    IF(_SelMonth = 1, _SelYear - 1, _SelYear)
			
			VAR _PrevMonth_Value =
			    CALCULATE(
			        DIVIDE(
			            SUM('Final_Fact'[Gtotal]),
			            DISTINCTCOUNT('Final_Fact'[DocEntry]),
			            0
			        ) / 1000,
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _PrevMonth_Year,
			        'DateTable'[Month No] = _PrevMonth
			    )
			
			VAR _Diff_Year  = _CurrYear_Value - _PrevYear_Value
			VAR _Diff_Month = _CurrValue_Numeric - _PrevMonth_Value
			
			RETURN
			SWITCH(
			    TRUE(),
			
			    _HasYear && NOT _HasMonth,
			        IF(_Diff_Year > 0,"#36A962",IF(_Diff_Year < 0,"#D44343","#000000")),
			
			    _HasYear && _HasMonth,
			        IF(_Diff_Month > 0,"#36A962",IF(_Diff_Month < 0,"#D44343","#000000")),
			
			    "#000000"
			)
		displayFolder: Avg Basket
		lineageTag: 54417b59-8803-42e8-9a5b-4d18cea1adb3

