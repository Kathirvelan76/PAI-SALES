			    IF(_SelMonth = 1, 12, _SelMonth - 1)
			
			VAR _PrevMonth_Year =
			    IF(_SelMonth = 1, _SelYear - 1, _SelYear)
			
			VAR _PrevMonth_Value =
			    CALCULATE(
			        [% Gross Profit],
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _PrevMonth_Year,
			        'DateTable'[Month No] = _PrevMonth
			    )
			
			VAR _Diff_Year  = _CurrYear_Value - _PrevYear_Value
			VAR _Diff_Month = _CurrValue - _PrevMonth_Value
			
			RETURN
			SWITCH(
			    TRUE(),
			
			    _HasYear && NOT _HasMonth,
			        IF(_Diff_Year > 0,"#36A962",IF(_Diff_Year < 0,"#D44343","#000000")),
			
			    _HasYear && _HasMonth,
			        IF(_Diff_Month > 0,"#36A962",IF(_Diff_Month < 0,"#D44343","#000000")),
			
			    "#000000"
			)
		displayFolder: Selling Price
		lineageTag: 1f596b35-7902-4071-8309-4627e6a27f92

