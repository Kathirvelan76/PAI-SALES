	measure 'DocEntry Total' = DISTINCTCOUNT(Final_Fact[DocEntry])
		formatString: 0
		displayFolder: DocEntry
		lineageTag: 1cac1899-7f2d-4440-bcdb-a8beee0ce61a

	measure 'DocEntry Previous Period' =
			
			
			VAR _HasYear  = HASONEVALUE('DateTable'[Financial Year])
			VAR _HasMonth = HASONEVALUE('DateTable'[Month No])
			
			VAR _SelFY =
			    SELECTEDVALUE('DateTable'[Financial Year])
			
			VAR _SelYear =
			    VALUE(LEFT(_SelFY,4))
			
			VAR _SelMonth =
			    SELECTEDVALUE('DateTable'[Month No])
			
			------------------------------------------------------
			-- Unit selection (default Lakhs for quantity)
			------------------------------------------------------
			
			VAR _SelectedUnit =
			    SELECTEDVALUE('Measure'[Unit], "Lakhs (L)")
			
			VAR _Divisor =
			    SWITCH(
			        _SelectedUnit,
			        "Lakhs (L)",     100000,
			        "Thousands (K)", 1000,
			        "Numbers (N)", 1,
			        1
			    )
			
			VAR _UnitSuffix =
			    SWITCH(
			        _SelectedUnit,
			        "Lakhs (L)",     "L",
			        "Thousands (K)", "K",
			        "Numbers (N)", "",
			        ""
			    )
			
			------------------------------------------------------
			-- Year comparison
			------------------------------------------------------
			
			VAR _PrevYear_Total =
			    CALCULATE(
			        DIVIDE([DocEntry Total], _Divisor),
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _SelYear - 1
			    )
			
			VAR _CurrYear_Total =
			    CALCULATE(
			        DIVIDE([DocEntry Total], _Divisor),
			        'DateTable'[FY Start Year] = _SelYear
			    )
			
			------------------------------------------------------
			-- Month comparison
			------------------------------------------------------
			
			VAR _PrevMonth =
			    IF(_SelMonth = 1, 12, _SelMonth - 1)
			
			VAR _PrevMonthYear =
			    IF(_SelMonth = 1, _SelYear - 1, _SelYear)
			
			VAR _PrevMonth_Total =
			    CALCULATE(
			        DIVIDE([DocEntry Total], _Divisor),
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _PrevMonthYear,
			        'DateTable'[Month No] = _PrevMonth
			    )
			
			VAR _CurrMonth_Total =
			    CALCULATE(
			        DIVIDE([DocEntry Total], _Divisor)
			    )
			
			------------------------------------------------------
			-- Differences
			------------------------------------------------------
			
			VAR _Diff_Year  = _CurrYear_Total  - _PrevYear_Total
			VAR _Perc_Year  = DIVIDE(_Diff_Year, _PrevYear_Total)
			
			VAR _Diff_Month = _CurrMonth_Total - _PrevMonth_Total
			VAR _Perc_Month = DIVIDE(_Diff_Month, _PrevMonth_Total)
			
			VAR _Arrow_Year  =
			    IF(_Diff_Year > 0,"⇧",IF(_Diff_Year < 0,"⇩",""))
			
			VAR _Arrow_Month =
			    IF(_Diff_Month > 0,"⇧",IF(_Diff_Month < 0,"⇩",""))
			
			------------------------------------------------------
			-- Final Output
			------------------------------------------------------
			
			RETURN
			SWITCH(
			    TRUE(),
			
			    _HasYear && NOT _HasMonth,
			        "vs Previous Year : " &
			        _Arrow_Year & " " &
			        FORMAT(_Diff_Year,"#,##0.00") & " " & _UnitSuffix &
			        " | " &
			        FORMAT(_Perc_Year,"0.0%"),
			
			    _HasYear && _HasMonth,
			        "vs Previous Period : " &
			        _Arrow_Month & " " &
			        FORMAT(_Diff_Month,"#,##0.00") & " " & _UnitSuffix &
			        " | " &
			        FORMAT(_Perc_Month,"0.0%"),
			
			    NOT _HasYear && NOT _HasMonth,
			        "vs Previous :",
			
			    BLANK()
			)
		displayFolder: DocEntry
		lineageTag: 0d4633e6-a9ae-4337-9ed9-c36d0b77ecd4

	measure 'Color DocEntry Previous Period' =
			
			
			VAR _HasYear  = HASONEVALUE('DateTable'[Financial Year])
			VAR _HasMonth = HASONEVALUE('DateTable'[Month No])
			
