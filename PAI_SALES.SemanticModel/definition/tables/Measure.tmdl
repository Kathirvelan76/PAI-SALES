	measure 'ASP Previous Period (Unit)' =
			
			
			VAR _HasYear  = HASONEVALUE('DateTable'[Financial Year])
			VAR _HasMonth = HASONEVALUE('DateTable'[Month No])
			
			VAR _SelFY =
			    SELECTEDVALUE('DateTable'[Financial Year])
			
			VAR _SelYear =
			    VALUE(LEFT(_SelFY,4))
			
			VAR _SelMonth =
			    SELECTEDVALUE('DateTable'[Month No])
			
			------------------------------------------------
			-- Current (RAW ASP)
			------------------------------------------------
			
			VAR _CurrValue =
			    [ASP]
			
			------------------------------------------------
			-- Year Comparison
			------------------------------------------------
			
			VAR _PrevYear_Value =
			    CALCULATE(
			        [ASP],
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _SelYear - 1
			    )
			
			VAR _CurrYear_Value =
			    CALCULATE(
			        [ASP],
			        'DateTable'[FY Start Year] = _SelYear
			    )
			
			------------------------------------------------
			-- Month Comparison
			------------------------------------------------
			
			VAR _PrevMonth =
			    IF(_SelMonth = 1, 12, _SelMonth - 1)
			
			VAR _PrevMonth_Year =
			    IF(_SelMonth = 1, _SelYear - 1, _SelYear)
			
			VAR _PrevMonth_Value =
			    CALCULATE(
			        [ASP],
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _PrevMonth_Year,
			        'DateTable'[Month No] = _PrevMonth
			    )
			
			VAR _CurrMonth_Value =
			    _CurrValue
			
			------------------------------------------------
			-- Differences (RAW)
			------------------------------------------------
			
			VAR _Diff_Year  = _CurrYear_Value  - _PrevYear_Value
			VAR _Perc_Year  = DIVIDE(_Diff_Year, _PrevYear_Value)
			
			VAR _Diff_Month = _CurrMonth_Value - _PrevMonth_Value
			VAR _Perc_Month = DIVIDE(_Diff_Month, _PrevMonth_Value)
			
			VAR _Arrow_Year  = IF(_Diff_Year > 0,"⇧",IF(_Diff_Year < 0,"⇩",""))
			VAR _Arrow_Month = IF(_Diff_Month > 0,"⇧",IF(_Diff_Month < 0,"⇩",""))
			
			------------------------------------------------
			-- UNIT LOGIC (ONLY HERE)
			------------------------------------------------
			
			VAR SelectedUnit =
			    SELECTEDVALUE('Measure'[Unit], "Thousands (K)")
			
			VAR Divisor =
			    SWITCH(
			        SelectedUnit,
			        "Thousands (K)", 1000,
			        "Numbers (N)",   1,
			        1000
			    )
			
			VAR Suffix =
			    SWITCH(
			        SelectedUnit,
			        "Thousands (K)", "K",
			        "Numbers (N)",   "",
			        ""
			    )
			
			------------------------------------------------
			RETURN
			------------------------------------------------
			
			SWITCH(
			    TRUE(),
			
			    _HasYear && NOT _HasMonth,
			        "vs Previous Year : " &
			        _Arrow_Year & " ₹" &
			        FORMAT(DIVIDE(_Diff_Year,Divisor),"#,##0.00") & " " & Suffix &
			        " | " &
			        FORMAT(_Perc_Year,"0.0%"),
			
			    _HasYear && _HasMonth,
			        "vs Previous Period : " &
			        _Arrow_Month & " ₹" &
			        FORMAT(DIVIDE(_Diff_Month,Divisor),"#,##0.00") & " " & Suffix &
			        " | " &
			        FORMAT(_Perc_Month,"0.0%"),
			
			    NOT _HasYear && NOT _HasMonth,
			        "vs Previous :",
			
			    BLANK()
			)
		displayFolder: Selling Price
		lineageTag: efb65c00-106f-4140-9cb3-28d7dd01b82a

	measure 'ASP Color Previous Period' =
			
			
			VAR _HasYear  = HASONEVALUE('DateTable'[Financial Year])
			VAR _HasMonth = HASONEVALUE('DateTable'[Month No])
			
			VAR _SelFY =
			    SELECTEDVALUE('DateTable'[Financial Year])
			
			VAR _SelYear =
			    VALUE(LEFT(_SelFY,4))
			
			VAR _SelMonth =
			    SELECTEDVALUE('DateTable'[Month No])
			
			VAR _CurrValue =
			    [ASP]
			
			VAR _PrevYear_Value =
			    CALCULATE(
			        [ASP],
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _SelYear - 1
			    )
			
			VAR _CurrYear_Value =
			    CALCULATE(
			        [ASP],
			        'DateTable'[FY Start Year] = _SelYear
			    )
			
			VAR _PrevMonth =
			    IF(_SelMonth = 1, 12, _SelMonth - 1)
			
			VAR _PrevMonth_Year =
			    IF(_SelMonth = 1, _SelYear - 1, _SelYear)
			
			VAR _PrevMonth_Value =
			    CALCULATE(
			        [ASP],
			        REMOVEFILTERS('DateTable'[Financial Year], 'DateTable'[Month No]),
			        'DateTable'[FY Start Year] = _PrevMonth_Year,
			        'DateTable'[Month No] = _PrevMonth
			    )
			
			VAR _Diff_Year  = _CurrYear_Value - _PrevYear_Value
			VAR _Diff_Month = _CurrValue - _PrevMonth_Value
			
			RETURN
			SWITCH(
			    TRUE(),
			
			    _HasYear && NOT _HasMonth,
			        IF(_Diff_Year > 0,"#36A962",IF(_Diff_Year < 0,"#D44343","#000000")),
			
			    _HasYear && _HasMonth,
			        IF(_Diff_Month > 0,"#36A962",IF(_Diff_Month < 0,"#D44343","#000000")),
			
			    "#000000"
			)
		displayFolder: Selling Price
		lineageTag: 7d79644e-e571-4c90-b2a7-0f39b325dbf0

