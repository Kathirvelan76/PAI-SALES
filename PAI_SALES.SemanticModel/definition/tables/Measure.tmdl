	measure 'Net 5' = ```
			
			VAR StartDate=[Start5]
			VAR EndDate=[End5]
			
			RETURN
			CALCULATE(
			    [Net Price Total],
			    FILTER(
			        ALL(DateTable),
			        DateTable[Date]>=StartDate &&
			        DateTable[Date]<=EndDate
			    )
			)
			
			```
		displayFolder: Compare
		lineageTag: 3c0d32d6-373b-4cea-ad1a-000cbf24bdd4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '2 Chart Range' =
			
			VAR StartDate = [Start2]
			VAR EndDate   = [End2]
			
			VAR MetricValue =
			    CALCULATE(
			        [2 Metric Using],
			        FILTER(
			            ALL('DateTable'),
			            'DateTable'[Date] >= StartDate &&
			            'DateTable'[Date] <= EndDate
			        )
			    )
			
			VAR SelectedMetric =
			    SELECTEDVALUE('Metric Switch'[Metric], "Sales")
			
			VAR UnitFromSlicer =
			    SELECTEDVALUE('Measure'[Unit])
			
			VAR DefaultUnit =
			    IF(
			        SelectedMetric = "Quantity",
			        "Lakhs (L)",
			        "Crores (Cr)"
			    )
			
			VAR FinalUnit =
			    COALESCE(UnitFromSlicer, DefaultUnit)
			
			RETURN
			SWITCH(
			    FinalUnit,
			    "Crores (Cr)", DIVIDE(MetricValue,10000000),
			    "Lakhs (L)",  DIVIDE(MetricValue,100000),
			    "Thousands (K)", DIVIDE(MetricValue,1000),
			    "Numbers (N)", MetricValue,
			    DIVIDE(MetricValue,10000000)
			)
		displayFolder: Compare
		lineageTag: a1ee7885-afed-4511-a6cf-f803f6e8adbf

		annotation PBI_FormatHint = {"isGeneralNumber":true}

