	measure 'Customers Who Bought Selected Category' = ```
			
			CALCULATETABLE(
			    VALUES('Cust_Vend_Master'[CardCode]),
			    REMOVEFILTERS('Warehouse_Master'),        -- ignore branch filter
			    REMOVEFILTERS('Cust_Vend_Master'),      -- ignore customer filter  
