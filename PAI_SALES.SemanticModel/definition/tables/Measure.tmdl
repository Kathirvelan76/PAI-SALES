	measure 'New Customers' =
			
			VAR StartDate = MIN(DateTable[Date])
			VAR EndDate   = MAX(DateTable[Date])
			
			RETURN
			CALCULATE(
			    DISTINCTCOUNT(Final_Fact[CardCode]),
			    Final_Fact[First Purchase Date] >= StartDate,
			    Final_Fact[First Purchase Date] <= EndDate
			)
		formatString: 0
		displayFolder: Campaign
		lineageTag: d25ff37e-1329-4684-b740-59787a3e0c84

	measure 'Returning Customers' =
			
			CALCULATE(
			    DISTINCTCOUNT(Final_Fact[CardCode]),
			    FILTER(
			        Final_Fact,
			        Final_Fact[DocDate] > Final_Fact[First Purchase Date]
			    )
			)
		formatString: 0
		displayFolder: Campaign
		lineageTag: 1c4c1e09-bfa0-47df-98e7-84b614a7bec6

	measure Customer_Acquisition_Cost =
			
