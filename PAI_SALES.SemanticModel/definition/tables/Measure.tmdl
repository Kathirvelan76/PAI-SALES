	measure 'Filter Customer by Purchase Count' = ```
			
			// 1. Capture Inputs
			VAR SelectedNMonths = [N Months Selected] 
			VAR SelectedCount = [Count Filter Selected] 
			VAR MinValue = [DMin Value Selected] 
			VAR MaxValue = [DMax Value Selected] 
			
			// 2. Define Time Window
			VAR TodayDate = TODAY() 
			// EDATE finds the date that is 'SelectedNMonths' before TodayDate
			VAR StartDate = EDATE(TodayDate, -SelectedNMonths) 
			
			// 3. Find Qualified Invoices for the current Customer
			VAR QualifiedInvoices = 
			    CALCULATETABLE(
			        // We only want to count distinct invoices
			        DISTINCT('Final_Fact'[DocEntry]),
			        
			        // Context filter 1: Date Range
			        'DateTable'[Date] >= StartDate,
			        'DateTable'[Date] <= TodayDate,
			        
			        // Context filter 2: Invoice Value Range
			        // Filter based on DocTotal, not GTotal, as requested
			        'Final_Fact'[Doctotal] >= MinValue,
			        'Final_Fact'[Doctotal] <= MaxValue
			    )
			
			// 4. Calculate the Actual Purchase Count
			VAR ActualPurchaseCount = 
			    COUNTROWS(QualifiedInvoices)
			
			// 5. Final Check
			RETURN 
			    IF(
			        ActualPurchaseCount = SelectedCount,
			        1, // YES: This customer meets all criteria
			        0  // NO: This customer fails the criteria
			    )
			```
		formatString: 0
		displayFolder: Extras
		lineageTag: 3e53ae8c-dd71-4aaf-94aa-ba9b69d37f07

