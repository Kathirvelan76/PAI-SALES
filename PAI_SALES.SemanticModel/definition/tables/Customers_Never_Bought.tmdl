table Customers_Never_Bought
	lineageTag: 014b5978-34e4-4749-84c4-49ec5a19d7ce

	column CardCode
		lineageTag: c0da7afa-8a5c-4b9c-b765-4afa51700f0b
		summarizeBy: none
		isNameInferred
		sourceColumn: Cust_Vend_Master[CardCode]

		annotation SummarizationSetBy = Automatic

	partition Customers_Never_Bought = calculated
		mode: import
		source =
				
				VAR AllCustomers =
				    DISTINCT('Cust_Vend_Master'[CardCode])
				
				VAR BoughtCustomers =
				    SELECTCOLUMNS(
				        'Customer_MainCategory',
				        "CardCode", 'Customer_MainCategory'[CardCode]
				    )
				
				RETURN
				    EXCEPT(AllCustomers, BoughtCustomers)

	annotation PBI_Id = 8828b50d9778486aba7a1a76e9ebf796

