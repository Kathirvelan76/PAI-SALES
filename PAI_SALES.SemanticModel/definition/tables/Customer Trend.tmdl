	column IsSeasonal =
			
			RELATED ( CustomerSeasonSummary[IsSeasonal] )
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 46815d38-4c25-4a55-923f-a6458499f2ec
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Segment = ```
			
			VAR MonthsSinceLast      = 'Customer Trend'[MonthsSinceLast]
			VAR MonthsBetween        = 'Customer Trend'[MonthsBetweenPurchases]
			VAR MinBill              = 'Customer Trend'[MinBill]
			VAR MaxBill              = 'Customer Trend'[MaxBill]
			VAR AvgBill              = 'Customer Trend'[AvgBill]
			VAR Purchases            = 'Customer Trend'[Purchase Count]
			VAR _FirstDate            = 'Customer Trend'[First Purchase Date]
			VAR IsSeasonalCustomer   = 'Customer Trend'[IsSeasonal]
			
			VAR IsLifetimeSuccessful =
			    NOT ISBLANK ( MonthsBetween )
			        && MonthsBetween <= 18
			
			VAR IsLoyal =
			    MaxBill >= 30000
			        && NOT ISBLANK ( MonthsBetween )
			        && MonthsBetween <= 36
			
			VAR IsHighValue =
			    MaxBill >= 70000
			        && NOT ISBLANK ( MonthsBetween )
			        && MonthsBetween <= 18
			
			VAR IsNew =
			    DATEDIFF ( _FirstDate, TODAY (), MONTH ) <= 6
			
			VAR IsOneTimeHighSpender =
			    MaxBill >= 80000
			        && Purchases = 1
			        && MonthsSinceLast >= 12
			
			VAR IsBudgetFrequent =
			    AvgBill <= 15000
			        && MonthsSinceLast <= 18
			
			VAR IsAtRisk =
			    MonthsSinceLast >= 12
			        && MonthsSinceLast <= 18
			        && ( IsLoyal || IsHighValue || IsNew )
			
			RETURN
			    SWITCH (
			        TRUE (),
			
			        IsSeasonalCustomer,   "Seasonal Shoppers",
			        IsAtRisk,             "At-Risk Customers",
			        IsBudgetFrequent,     "Budget-Conscious Frequent Buyers",
			        IsOneTimeHighSpender, "One-time High Spenders",
			        IsHighValue,          "High Value Customers",
			        IsLoyal,              "Loyal Customers",
			        IsLifetimeSuccessful, "Lifetime Successful Customers",
			        IsNew,                "New Customers",
			        "Unclassified"
			    )
			
			```
		lineageTag: 48d6267f-0d95-4a9d-8647-6a3af349e3aa
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

