	partition 'Customer Trend' = calculated
		mode: import
		source =
				
				SUMMARIZE(
				    FILTER(
				        'Final_Fact',
				        'Final_Fact'[Type] = "SI"
				    ),
				    'Final_Fact'[CardCode],
				    "CardName", MAX('Final_Fact'[CardName]),
				    "Purchase Count", DISTINCTCOUNT('Final_Fact'[DocEntry]),
				    "First Purchase Date", MIN('Final_Fact'[DocDate]),
				    "Last Purchase Date", MAX('Final_Fact'[DocDate])
				)

	annotation PBI_Id = 1e8afab5559346d1a57211275b8d67fd

