	column MonthsSinceLast = ```
			
			DATEDIFF (
			    'Customer Trend'[Last Purchase Date],
			    TODAY (),
			    MONTH
			)
			
			```
		formatString: 0
		lineageTag: 0fe2d330-2b1c-4246-832a-de82337624dd
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column MonthsBetweenPurchases = ```
			
			VAR _FirstDate  = 'Customer Trend'[First Purchase Date]
			VAR _LastDate   = 'Customer Trend'[Last Purchase Date]
			VAR _Purchases  = 'Customer Trend'[Purchase Count]
			VAR _MonthsSpan = DATEDIFF ( _FirstDate, _LastDate, MONTH )
			RETURN
			IF ( _Purchases > 1, DIVIDE ( _MonthsSpan, _Purchases - 1 ), BLANK () )
			
			```
		dataType: int64
		lineageTag: dbd1d1c4-b685-402c-98ce-8b7fc087484c
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column MinBill =
			
			VAR CustID = 'Customer Trend'[CardCode]
			VAR InvoiceTable =
			    SUMMARIZE (
			        FILTER (
			            'Final_Fact',
			            'Final_Fact'[CardCode] = CustID
			        ),
			        'Final_Fact'[DocEntry],
			        "InvoiceTotal", MAX ( 'Final_Fact'[Doctotal] )
			    )
			RETURN
			MINX ( InvoiceTable, [InvoiceTotal] )
		lineageTag: e4dee9f4-44fc-450e-a9f9-bc509c67959b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column MaxBill = ```
			
			VAR CustID = 'Customer Trend'[CardCode]
			VAR InvoiceTable =
			    SUMMARIZE (
			        FILTER ( 'Final_Fact', 'Final_Fact'[CardCode] = CustID ),
			        'Final_Fact'[DocEntry],
			        "InvoiceTotal", MAX ( 'Final_Fact'[Doctotal] )
			    )
			RETURN
			MAXX ( InvoiceTable, [InvoiceTotal] )
			
			```
		lineageTag: 115beeda-5ff6-4a69-8611-ba43545ed312
